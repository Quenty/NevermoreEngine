{
  "name": "RemotingTest",
  "globIgnorePaths": [
    "**/.package-lock.json",
    "**/.pnpm",
    "**/.pnpm-workspace-state-v1.json",
    "**/.modules.yaml",
    "**/.ignored",
    "**/.ignored_*"
  ],
  "tree": {
    "$className": "DataModel",
    "ServerScriptService": {
      "$properties": {
        "LoadStringEnabled": true
      },
      "remoting": {
        "$path": ".."
      },
      "Script": {
        "$path": "scripts/Server"
      }
    }
  }
}
